{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lacca.local/schemas/interior-buckets-v1.schema.json",
  "title": "InteriorBucketsV1",
  "type": "object",
  "required": ["scopeId", "version", "buckets"],
  "properties": {
    "$schema": { "type": "string" },
    "scopeId": { "type": "string" },
    "version": { "type": "string" },
    "notes": { "type": "string" },
    "buckets": {
      "type": "array",
      "minItems": 4,
      "maxItems": 12,
      "items": {
        "type": "object",
        "required": ["bucketId", "label", "lab"],
        "properties": {
          "bucketId": { "type": "string", "pattern": "^[a-z0-9_]+$" },
          "label": { "type": "string" },
          "description": { "type": "string" },
          "exampleOemTrims": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Marketing names for this OEM scope — not exhaustive."
          },
          "lab": { "$ref": "./lab-measurement-v1.schema.json" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
