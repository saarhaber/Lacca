{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lacca.local/schemas/oem-scope-v1.schema.json",
  "title": "OemScopeV1",
  "type": "object",
  "required": ["scopeId", "oem", "modelYears", "models", "exteriorPaintFile"],
  "properties": {
    "$schema": { "type": "string" },
    "scopeId": { "type": "string" },
    "oem": { "type": "string" },
    "region": { "type": "string" },
    "modelYears": {
      "type": "object",
      "required": ["from", "to"],
      "properties": {
        "from": { "type": "integer" },
        "to": { "type": "integer" }
      },
      "additionalProperties": false
    },
    "models": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 0,
      "description": "Models this scope applies to. May be empty for raw-source scopes (e.g. per-OEM PaintRef dumps) that feed a merger but do not surface in the UI."
    },
    "supersedes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Other scopeIds whose data this scope replaces. UI and downstream consumers should hide any scope listed here when this scope is present."
    },
    "notes": { "type": "string" },
    "exteriorPaintFile": { "type": "string" }
  },
  "additionalProperties": false
}
