{
  "name": "lacca",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "check": "npm run validate:data && npm run check:delta-e && npm run match:demo",
    "validate:data": "tsx scripts/validate-data.ts",
    "match:demo": "tsx scripts/demo-match.ts",
    "seed:opi": "tsx scripts/seed-opi-catalog.ts",
    "sync:opi": "tsx scripts/sync-opi-from-opicom.ts",
    "check:delta-e": "tsx scripts/check-delta-e.ts",
    "import:csv": "tsx scripts/import-kaggle-csv.ts",
    "fetch:paintref": "tsx scripts/fetch-paintref-colors.ts",
    "fetch:paintref:all": "tsx scripts/fetch-paintref-all.ts",
    "fetch:acl-page": "tsx scripts/fetch-autocolorlibrary-page.ts",
    "crawl:acl-site": "tsx scripts/crawl-autocolorlibrary-site.ts",
    "import:acl-labels": "tsx scripts/import-autocolorlibrary-labels.ts",
    "acl:tesseract-batch": "tsx scripts/acl-tesseract-batch.ts",
    "acl:sanitize-scopes": "tsx scripts/acl-sanitize-autocolorlibrary-scopes.ts",
    "merge:oem": "tsx scripts/merge-oem-scopes.ts",
